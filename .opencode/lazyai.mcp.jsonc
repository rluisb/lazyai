{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "atlassian": {
      "enabled": false,
      "type": "remote",
      "url": "https://mcp.atlassian.com/v1/mcp/authv2"
    },
    "codegraph": {
      "command": [
        "codegraph",
        "serve",
        "--mcp"
      ],
      "enabled": true,
      "type": "local"
    },
    "context7": {
      "enabled": false,
      "headers": {
        "CONTEXT7_API_KEY": "{env:CONTEXT7_API_KEY}"
      },
      "type": "remote",
      "url": "https://mcp.context7.com/mcp"
    },
    "fetch": {
      "command": [
        "npx",
        "-y",
        "@modelcontextprotocol/server-fetch"
      ],
      "enabled": false,
      "type": "local"
    },
    "filesystem": {
      "command": [
        "npx",
        "-y",
        "@modelcontextprotocol/server-filesystem",
        "."
      ],
      "enabled": true,
      "type": "local"
    },
    "github": {
      "enabled": false,
      "headers": {
        "Authorization": "Bearer {env:GITHUB_PERSONAL_ACCESS_TOKEN}"
      },
      "type": "remote",
      "url": "https://api.githubcopilot.com/mcp/"
    },
    "graphify": {
      "command": [
        "graphify",
        "query"
      ],
      "enabled": true,
      "type": "local"
    },
    "memoria": {
      "command": [
        "npx",
        "-y",
        "@byronwade/memoria"
      ],
      "enabled": true,
      "type": "local"
    },
    "memory": {
      "command": [
        "npx",
        "-y",
        "@modelcontextprotocol/server-memory"
      ],
      "enabled": true,
      "type": "local"
    },
    "obsidian": {
      "command": [
        "ob",
        "mcp"
      ],
      "enabled": true,
      "type": "local"
    },
    "playwright": {
      "command": [
        "npx",
        "-y",
        "@playwright/mcp",
        "--headless"
      ],
      "enabled": true,
      "type": "local"
    },
    "qmd": {
      "command": [
        "qmd",
        "mcp"
      ],
      "enabled": true,
      "type": "local"
    },
    "ripgrep": {
      "command": [
        "npx",
        "-y",
        "mcp-ripgrep"
      ],
      "enabled": true,
      "type": "local"
    }
  }
}
