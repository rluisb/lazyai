{
  "$schema": "https://opencode.ai/config.json",
  "default_agent": "primary-agent",
  "instructions": [
    "../AGENTS.md"
  ],
  "mcp": {
    "atlassian": {
      "command": [
        "npx",
        "-y",
        "mcp-remote@latest",
        "https://mcp.atlassian.com/v1/mcp"
      ],
      "enabled": false,
      "type": "local"
    },
    "brave-search": {
      "command": [
        "npx",
        "-y",
        "@modelcontextprotocol/server-brave-search"
      ],
      "enabled": false,
      "environment": {
        "BRAVE_API_KEY": "{env:BRAVE_API_KEY}"
      },
      "type": "local"
    },
    "codegraph": {
      "command": [
        "codegraph",
        "serve",
        "--mcp"
      ],
      "enabled": true,
      "type": "local"
    },
    "context7": {
      "enabled": false,
      "headers": {
        "Authorization": "Bearer {env:CONTEXT7_API_KEY}"
      },
      "type": "remote",
      "url": "https://mcp.context7.com/mcp"
    },
    "fetch": {
      "command": [
        "npx",
        "-y",
        "@modelcontextprotocol/server-fetch"
      ],
      "enabled": false,
      "type": "local"
    },
    "filesystem": {
      "command": [
        "npx",
        "-y",
        "@modelcontextprotocol/server-filesystem",
        "."
      ],
      "enabled": true,
      "type": "local"
    },
    "github": {
      "enabled": false,
      "headers": {
        "Authorization": "Bearer {env:GITHUB_PERSONAL_ACCESS_TOKEN}"
      },
      "type": "remote",
      "url": "https://api.githubcopilot.com/mcp/"
    },
    "graphify": {
      "command": [
        "graphify",
        "query"
      ],
      "enabled": true,
      "type": "local"
    },
    "memoria": {
      "command": [
        "npx",
        "-y",
        "@byronwade/memoria"
      ],
      "enabled": true,
      "type": "local"
    },
    "memory": {
      "command": [
        "npx",
        "-y",
        "@modelcontextprotocol/server-memory"
      ],
      "enabled": true,
      "type": "local"
    },
    "obsidian": {
      "command": [
        "ob",
        "mcp"
      ],
      "enabled": true,
      "type": "local"
    },
    "orchestrator": {
      "command": [
        "lazyai-orchestrator",
        "connect"
      ],
      "enabled": false,
      "type": "local"
    },
    "playwright": {
      "command": [
        "npx",
        "-y",
        "@playwright/mcp",
        "--headless"
      ],
      "enabled": false,
      "type": "local"
    },
    "qmd": {
      "command": [
        "qmd",
        "mcp"
      ],
      "enabled": true,
      "type": "local"
    },
    "ripgrep": {
      "command": [
        "npx",
        "-y",
        "mcp-ripgrep"
      ],
      "enabled": true,
      "type": "local"
    }
  },
  "permission": {
    "bash": "ask",
    "edit": "ask",
    "skill": {
      "*": "allow"
    }
  },
  "skills": {
    "paths": [
      "skills"
    ]
  }
}
