#!/usr/bin/env bash
# sidecar — CLI wrapper for the sidecar workspace manager
# Dispatches to individual scripts: init, add, index, query
#
# Usage: sidecar <command> [args...]
#   sidecar init [args...]     → sidecar-init.sh
#   sidecar add [args...]      → sidecar-add.sh
#   sidecar index [args...]    → sidecar-index.sh
#   sidecar query [args...]    → sidecar-query.sh
#   sidecar help               → show this usage
#   sidecar --help             → show this usage

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# ---------------------------------------------------------------------------
# Usage
# ---------------------------------------------------------------------------
usage() {
    cat <<EOF
Usage: sidecar <command> [args...]

Commands:
  init [args...]     Interactive workspace setup
  add [args...]      Add a repo to the workspace
  index [args...]    Rebuild the spec-to-repo SQLite index
  query [args...]    Query specs relevant to a repo
  help               Show this usage message

Examples:
  sidecar init
  sidecar add fedora
  sidecar query fedora --json
  sidecar index --force
EOF
}

# ---------------------------------------------------------------------------
# Dispatch
# ---------------------------------------------------------------------------
if [[ $# -eq 0 ]]; then
    echo "Error: no command provided." >&2
    usage >&2
    exit 1
fi

COMMAND="${1:-}"
shift || true

case "$COMMAND" in
    init)
        exec "$SCRIPT_DIR/sidecar-init.sh" "$@"
        ;;
    add)
        exec "$SCRIPT_DIR/sidecar-add.sh" "$@"
        ;;
    index)
        exec "$SCRIPT_DIR/sidecar-index.sh" "$@"
        ;;
    query)
        exec "$SCRIPT_DIR/sidecar-query.sh" "$@"
        ;;
    help|--help|-h)
        usage
        exit 0
        ;;
    *)
        echo "Error: unknown command '$COMMAND'." >&2
        usage >&2
        exit 1
        ;;
esac
