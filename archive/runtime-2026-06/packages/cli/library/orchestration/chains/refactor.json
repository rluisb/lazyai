{
  "kind": "chain",
  "name": "refactor",
  "description": "Phased refactor flow with approval before implementation",
  "version": "1.0.0",
  "entry": "research",
  "domain_skill_injection": "all_steps",
  "mode_skill_injection": "builder_steps_only",
  "steps": [
    {
      "id": "research",
      "agent": "scout",
      "skills": ["research", "extract-standards"],
      "description": "Map the current pattern, target pattern, and migration risks.",
      "transitions": {
        "success": "plan",
        "failure": {
          "retry": 1,
          "then": "handoff"
        }
      }
    },
    {
      "id": "plan",
      "agent": "planner",
      "skills": ["plan"],
      "description": "Create a phased refactor plan and stop for approval before code changes begin.",
      "gate": "user_approval",
      "transitions": {
        "approved": "implement",
        "rejected": "research"
      }
    },
    {
      "id": "implement",
      "agent": "builder",
      "skills": ["implement", "tdd-loop"],
      "description": "Implement the approved refactor incrementally while preserving behavior.",
      "transitions": {
        "success": "verify",
        "failure": {
          "retry": 2,
          "then": "plan"
        }
      }
    },
    {
      "id": "verify",
      "agent": "reviewer",
      "skills": [],
      "description": "Confirm the refactor preserved behavior and reduced the intended complexity.",
      "transitions": {
        "pass": "document",
        "blocking": "implement"
      }
    },
    {
      "id": "document",
      "agent": "documenter",
      "skills": [],
      "description": "Update architecture and maintenance notes affected by the refactor.",
      "transitions": {
        "success": "done"
      }
    }
  ]
}
