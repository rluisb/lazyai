{
  "kind": "chain",
  "name": "review",
  "description": "Sequential code review from mapping through adversarial analysis and synthesis",
  "version": "1.0.0",
  "entry": "map_changes",
  "domain_skill_injection": "all_steps",
  "mode_skill_injection": "none",
  "steps": [
    {
      "id": "map_changes",
      "agent": "scout",
      "skills": ["research"],
      "description": "Map the changed files, touched subsystems, and likely risk areas before review starts.",
      "transitions": {
        "success": "review_correctness",
        "failure": {
          "retry": 1,
          "then": "handoff"
        }
      }
    },
    {
      "id": "review_correctness",
      "agent": "reviewer",
      "skills": ["extract-standards"],
      "description": "Review correctness, edge cases, and standards alignment.",
      "transitions": {
        "success": "adversarial_review",
        "failure": "handoff"
      }
    },
    {
      "id": "adversarial_review",
      "agent": "red-team",
      "skills": [],
      "description": "Stress the change from a security and misuse perspective.",
      "transitions": {
        "success": "synthesize",
        "failure": "handoff"
      }
    },
    {
      "id": "synthesize",
      "agent": "orchestrator",
      "skills": [],
      "description": "Combine the findings into a clear verdict with prioritized next actions.",
      "transitions": {
        "success": "done"
      }
    }
  ]
}
