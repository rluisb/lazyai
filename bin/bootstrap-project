#!/usr/bin/env bash
# bin/bootstrap-project — Install lazyai into a target git repo.
#
# Usage: bin/bootstrap-project [TARGET_DIR] [OPTIONS]
#   TARGET_DIR    Path to target git repo (default: .)
#   --dry-run     Show what would happen without writing
#   --force       Overwrite user-owned files (dangerous)
#   --help        Show usage and exit
#
# Exit codes:
#   0  Success
#   1  Usage error
#   2  Target is not a git repo
#   3  Ambiguous ownership detected
#   4  Post-install doctor failures

set -euo pipefail
export LC_ALL=C

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
VIBE_LAB_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"
TARGET_DIR="${1:-.}"
DRY_RUN=false
FORCE=false

log() { printf "[bootstrap] %s\n" "$*"; }
warn() { printf "[bootstrap] WARN: %s\n" "$*" >&2; }
fail() {
  local code="${2:-1}"
  printf "[bootstrap] FAIL: %s\n" "$1" >&2
  exit "$code"
}

usage() {
  cat <<"EOF"
Usage: bin/bootstrap-project [TARGET_DIR] [OPTIONS]

  TARGET_DIR    Path to target git repo (default: .)
  --dry-run     Show what would happen without writing
  --force       Overwrite user-owned files (dangerous)
  --help        Show usage and exit

Exit codes:
  0  Success
  1  Usage error
  2  Target is not a git repo
  3  Ambiguous ownership detected
  4  Post-install doctor failures
EOF
}

# Parse arguments
while [ "$#" -gt 0 ]; do
  case "$1" in
    --dry-run)
      DRY_RUN=true
      shift
      ;;
    --force)
      FORCE=true
      shift
      ;;
    --help|-h)
      usage
      exit 0
      ;;
    -*)
      usage >&2
      fail "Unknown option \u0027$1\u0027" 1
      ;;
    *)
      TARGET_DIR="$1"
      shift
      ;;
  esac
done

# Resolve target to absolute path
if [ ! -d "$TARGET_DIR" ]; then
  fail "Target directory does not exist: $TARGET_DIR" 1
fi
TARGET_DIR="$(cd "$TARGET_DIR" && pwd)"

# Validate target is a git repo
if [ ! -d "$TARGET_DIR/.git" ]; then
  fail "Target is not a git repo: $TARGET_DIR" 2
fi

# Prevent bootstrapping into self
if [ "$TARGET_DIR" = "$VIBE_LAB_ROOT" ]; then
  fail "Cannot bootstrap into the lazyai repo itself" 1
fi

log "Bootstrapping lazyai into $TARGET_DIR"

# Ownership marker detection
is_vibe_lab_owned() {
  local file="$1"
  if [ ! -f "$file" ]; then
    return 1
  fi
  if grep -q "Generated by bin/inject" "$file" 2>/dev/null || \
     grep -q "vibe-lab canonical" "$file" 2>/dev/null || \
     grep -q "vibe-lab:managed" "$file" 2>/dev/null; then
    return 0
  fi
  return 1
}

OWNERSHIP_CONFLICTS=0

# Safe copy with ownership check
safe_copy() {
  local src="$1"
  local dest="$2"
  local label="${3:-file}"

  if [ -f "$dest" ] && ! is_vibe_lab_owned "$dest" && ! $FORCE; then
    warn "Would overwrite user-owned $label: ${dest#$TARGET_DIR/}"
    OWNERSHIP_CONFLICTS=$((OWNERSHIP_CONFLICTS + 1))
    return 3
  fi

  if $DRY_RUN; then
    log "[DRY RUN] Would copy $label: ${src#$VIBE_LAB_ROOT/} → ${dest#$TARGET_DIR/}"
    return 0
  fi

  mkdir -p "$(dirname "$dest")"
  cp -f "$src" "$dest"
  log "Copied $label: ${dest#$TARGET_DIR/}"
}

# Safe sync directory
safe_sync_dir() {
  local src_dir="$1"
  local dest_dir="$2"
  local label="${3:-directory}"

  if [ ! -d "$src_dir" ]; then
    warn "Source $label does not exist: ${src_dir#$VIBE_LAB_ROOT/}"
    return 0
  fi

  if $DRY_RUN; then
    log "[DRY RUN] Would sync $label: ${src_dir#$VIBE_LAB_ROOT/} → ${dest_dir#$TARGET_DIR/}"
    return 0
  fi

  mkdir -p "$dest_dir"
  (cd "$src_dir" && find . -type f -print0) | while IFS= read -r -d "" rel; do
    local src_file="$src_dir/$rel"
    local dest_file="$dest_dir/$rel"
    mkdir -p "$(dirname "$dest_file")"
    cp -f "$src_file" "$dest_file"
  done
  log "Synced $label: ${dest_dir#$TARGET_DIR/}"
}

# Detect surfaces
detect_surfaces() {
  local surfaces=""
  [ -d "$TARGET_DIR/.claude" ] && surfaces+=" claude"
  [ -d "$TARGET_DIR/.opencode" ] && surfaces+=" opencode"
  [ -d "$TARGET_DIR/.pi" ] && surfaces+=" pi"
  [ -d "$TARGET_DIR/.specify" ] && surfaces+=" specify"
  printf "%s" "${surfaces# }"
}

# ── Copy canonical sources ──
if [ -d "$VIBE_LAB_ROOT/canonical" ]; then
  if $DRY_RUN; then
    log "[DRY RUN] Would sync canonical/"
  else
    safe_sync_dir "$VIBE_LAB_ROOT/canonical" "$TARGET_DIR/canonical" "canonical sources"
  fi
fi

# ── Copy .agents/ (skills, agents, hooks, workflows) ──
if [ -d "$VIBE_LAB_ROOT/.agents" ]; then
  if $DRY_RUN; then
    log "[DRY RUN] Would sync .agents/"
  else
    safe_sync_dir "$VIBE_LAB_ROOT/.agents" "$TARGET_DIR/.agents" "agent definitions"
  fi
fi

# ── Copy bin/ scripts ──
mkdir -p "$TARGET_DIR/bin"

for script in inject doctor startup-self-heal; do
  src="$VIBE_LAB_ROOT/bin/$script"
  dest="$TARGET_DIR/bin/$script"
  if [ ! -f "$src" ]; then
    warn "Source script not found: bin/$script"
    continue
  fi
  if [ -f "$dest" ] && ! is_vibe_lab_owned "$dest" && ! $FORCE; then
    warn "User-owned file would be overwritten: bin/$script"
    OWNERSHIP_CONFLICTS=$((OWNERSHIP_CONFLICTS + 1))
    continue
  fi
  if $DRY_RUN; then
    log "[DRY RUN] Would copy bin/$script"
  else
    cp -f "$src" "$dest"
    chmod +x "$dest"
    log "Copied bin/$script"
  fi
done

# ── Copy tests/ ──
if [ -d "$VIBE_LAB_ROOT/tests" ]; then
  if $DRY_RUN; then
    log "[DRY RUN] Would sync tests/"
  else
    safe_sync_dir "$VIBE_LAB_ROOT/tests" "$TARGET_DIR/tests" "test suite"
  fi
fi

# ── Copy docs/ (optional) ──
if [ -d "$VIBE_LAB_ROOT/docs" ]; then
  if $DRY_RUN; then
    log "[DRY RUN] Would sync docs/"
  else
    safe_sync_dir "$VIBE_LAB_ROOT/docs" "$TARGET_DIR/docs" "documentation"
  fi
fi

# Check for ownership conflicts
if [ "$OWNERSHIP_CONFLICTS" -gt 0 ] && ! $FORCE && ! $DRY_RUN; then
  fail "$OWNERSHIP_CONFLICTS user-owned file(s) would be overwritten. Use --force to override, or resolve conflicts manually" 3
fi

if $DRY_RUN; then
  log "[DRY RUN] Complete. No files were written."
  log "Detected surfaces: $(detect_surfaces)"
  exit 0
fi

# ── Run inject in target ──
log "Running bin/inject in target..."
if [ -x "$TARGET_DIR/bin/inject" ]; then
  if ! "$TARGET_DIR/bin/inject"; then
    fail "bin/inject failed in target directory" 4
  fi
else
  fail "bin/inject not executable in target directory" 4
fi

# ── Run doctor in target ──
log "Running bin/doctor in target..."
if [ -x "$TARGET_DIR/bin/doctor" ]; then
  if ! "$TARGET_DIR/bin/doctor"; then
    fail "bin/doctor reported failures in target directory" 4
  fi
else
  fail "bin/doctor not executable in target directory" 4
fi

log "Bootstrap complete. lazyai installed in $TARGET_DIR"
log "Detected surfaces: $(detect_surfaces)"
log "Restart Claude Code or OpenCode sessions for changes to take effect."
exit 0
