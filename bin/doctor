  if [ "$actual" -ne 0 ]; then
    fail_assert "objective-workflow-gate Copilot $label exited $actual"
  elif python3 - "$tmp" "$expected" <<'PY'
import json
import pathlib
import sys

path = pathlib.Path(sys.argv[1])
expected = sys.argv[2]
text = path.read_text()
if expected == "allow":
    if text.strip():
        raise SystemExit(1)
else:
    data = json.loads(text)
    if data.get("decision") != "block" or not data.get("reason"):
        raise SystemExit(1)
PY
  then
    pass_assert "objective-workflow-gate Copilot $label"
