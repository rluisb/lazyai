  fi
  rm -f "$tmp"
}

run_antigravity_hook_case() {
  local label="$1"
  local input="$2"
  local expected_exit="$3"
  local expected_decision="$4"
  local hook="$REPO_ROOT/.gemini/hooks/lazyai/block-destructive-shell.sh"
  local tmp actual
  tmp="$(mktemp "${TMPDIR:-/tmp}/vibe-lab-antigravity-hook.XXXXXX")"
  actual="$(printf '%s' "$input" | "$hook" >"$tmp"; printf '%s' "$?")"
  if [ "$actual" -ne "$expected_exit" ]; then
    fail_assert "block-destructive-shell Antigravity $label exited $actual (expected $expected_exit)"
  elif python3 - "$tmp" "$expected_decision" <<'PY'
import json, pathlib, sys
path = pathlib.Path(sys.argv[1])
expected = sys.argv[2]
try:
    data = json.loads(path.read_text())
    if data.get("decision") != expected:
        sys.exit(1)
except Exception:
    sys.exit(1)
PY
  then
    pass_assert "block-destructive-shell Antigravity $label"
  else
    fail_assert "block-destructive-shell Antigravity $label output mismatch"
  fi
  rm -f "$tmp"
}

run_antigravity_objective_gate_case() {
  local label="$1"
  local input="$2"
  local expected_exit="$3"
  local expected_decision="$4"
  local hook="$REPO_ROOT/.gemini/hooks/lazyai/objective-workflow-gate.sh"
  local tmp actual
  tmp="$(mktemp "${TMPDIR:-/tmp}/vibe-lab-antigravity-gate.XXXXXX")"
  actual="$(printf '%s' "$input" | "$hook" >"$tmp"; printf '%s' "$?")"
  if [ "$actual" -ne "$expected_exit" ]; then
    fail_assert "objective-workflow-gate Antigravity $label exited $actual (expected $expected_exit)"
  elif python3 - "$tmp" "$expected_decision" <<'PY'
import json, pathlib, sys
path = pathlib.Path(sys.argv[1])
expected = sys.argv[2]
try:
    data = json.loads(path.read_text())
    if data.get("decision") != expected:
        sys.exit(1)
    if expected == "deny" and not data.get("reason"):
        sys.exit(1)
except Exception:
    sys.exit(1)
PY
  then
    pass_assert "objective-workflow-gate Antigravity $label"
  else
    fail_assert "objective-workflow-gate Antigravity $label output mismatch"
  fi
  rm -f "$tmp"
}

run_opencode_hook_tests() {
  local plugin="$REPO_ROOT/.opencode/plugins/lazyai-hooks.js"
  if [ ! -f "$plugin" ]; then
    fail_assert "OpenCode plugin missing"
    return
  fi
  if node --input-type=module - "$plugin" "$REPO_ROOT" <<'JS' >/dev/null
const pluginPath = process.argv[2];
const repoRoot = process.argv[3];
const mod = await import(pluginPath);
const hooks = await mod.LazyAIHooks({ directory: repoRoot });
if (typeof hooks.event !== "function") throw new Error("startup event hook missing");
await hooks.event({ event: { type: "session.created" } });
const before = hooks["tool.execute.before"];
await before({ tool: "bash" }, { args: { command: "printf ok" } });
await before({ tool: "read" }, { args: {} });
let denied = false;
try {
  await before({ tool: "bash" }, { args: { command: "rm -rf /" } });
} catch {
  denied = true;
}
if (!denied) throw new Error("denied command was allowed");
let missing = false;
try {
  await before({ tool: "bash" }, { args: {} });
} catch {
  missing = true;
}
if (!missing) throw new Error("missing command was allowed");
let gateDenied = false;
try {
  await hooks.event({ event: { type: "session.idle", lastAssistantMessage: "Done. Implemented the change." } });
} catch {
  gateDenied = true;
}
if (!gateDenied) throw new Error("objective gate allowed completion without evidence");
await hooks.event({ event: { type: "session.idle", lastAssistantMessage: "Done.\n\nVerification: bin/doctor --test-hooks passed." } });
await hooks.event({ event: { type: "message.updated", message: { role: "assistant", content: "Done. Implemented the change." } } });
gateDenied = false;
try {
  await hooks.event({ event: { type: "session.idle" } });
} catch {
  gateDenied = true;
}
if (!gateDenied) throw new Error("objective gate ignored stored assistant completion without evidence");
JS
  then
    pass_assert "OpenCode plugin smoke runs startup, Bash guard, and objective workflow gate"
  else
    fail_assert "OpenCode plugin smoke failed"
  fi
}

check_hook_functionality() {
  section "Hook Functionality"
  if ! $TEST_HOOKS; then
    ok "Hook functionality skipped (use --test-hooks)"
    return
  fi
  if uses_claude; then
    local hook="$REPO_ROOT/.claude/hooks/block-destructive-shell.sh"
    [ -x "$hook" ] || { fail_assert "block-destructive-shell hook missing or not executable"; return; }
    local objective_hook="$REPO_ROOT/.claude/hooks/objective-workflow-gate.sh"
    [ -x "$objective_hook" ] || { fail_assert "objective-workflow-gate hook missing or not executable"; return; }
    local policy="$AGENTS_HOOKS_DIR/block-destructive-shell/POLICY.md"
    local denied_prefixes=()
    if [ -f "$policy" ]; then
      mapfile -t denied_prefixes < <(extract_denied_prefixes "$policy") || fail_assert "block-destructive-shell policy has no deterministic denied command spans"
    fi
    [ "${#denied_prefixes[@]}" -gt 0 ] || fail_assert "block-destructive-shell denied prefix list empty"

    run_claude_objective_gate_case "blocks completion claim without evidence" '{"hook_event_name":"Stop","stop_hook_active":false,"last_assistant_message":"Done. Implemented the change."}' block
    run_claude_objective_gate_case "allows completion claim with verification" '{"hook_event_name":"Stop","stop_hook_active":false,"last_assistant_message":"Done.\n\nVerification: bin/doctor --test-hooks passed."}' allow
    run_claude_objective_gate_case "allows repeated stop feedback turn" '{"hook_event_name":"Stop","stop_hook_active":true,"last_assistant_message":"Done. Implemented the change."}' allow

    run_claude_hook_case "fails closed on malformed JSON" '{' 2
    run_claude_hook_case "fails closed on missing Bash command" '{"tool_name":"Bash","tool_input":{}}' 2
    run_claude_hook_case "fails closed on non-string Bash command" '{"tool_name":"Bash","tool_input":{"command":42}}' 2
    for prefix in "${denied_prefixes[@]}"; do
      run_claude_hook_case "denies $prefix" "{\"tool_name\":\"Bash\",\"tool_input\":{\"command\":\"$prefix\"}}" 2
    done
    run_claude_hook_case "allows safe Bash" '{"tool_name":"Bash","tool_input":{"command":"printf ok"}}' 0
    run_claude_hook_case "passes non-Bash" '{"tool_name":"Read","tool_input":{"file_path":"README.md"}}' 0
  fi
  if uses_copilot; then
    local hook="$REPO_ROOT/.github/hooks/block-destructive-shell.sh"
    [ -x "$hook" ] || { fail_assert "block-destructive-shell Copilot hook missing or not executable"; return; }
    local objective_hook="$REPO_ROOT/.github/hooks/objective-workflow-gate.sh"
    [ -x "$objective_hook" ] || { fail_assert "objective-workflow-gate Copilot hook missing or not executable"; return; }
    local policy="$AGENTS_HOOKS_DIR/block-destructive-shell/POLICY.md"
    local denied_prefixes=()
    if [ -f "$policy" ]; then
      mapfile -t denied_prefixes < <(extract_denied_prefixes "$policy") || fail_assert "block-destructive-shell policy has no deterministic denied command spans"
    fi
    [ "${#denied_prefixes[@]}" -gt 0 ] || fail_assert "block-destructive-shell denied prefix list empty"

    run_copilot_objective_gate_case "blocks completion claim without evidence" '{"eventName":"agentStop","lastAssistantMessage":"Done. Implemented the change."}' block
    run_copilot_objective_gate_case "allows completion claim with verification" '{"eventName":"agentStop","lastAssistantMessage":"Done.\n\nVerification: bin/doctor --test-hooks passed."}' allow

    run_copilot_hook_case "fails closed on malformed JSON" '{' 2
    run_copilot_hook_case "fails closed on missing Bash command" '{"toolName":"bash","toolInput":{}}' 2
    run_copilot_hook_case "fails closed on non-string Bash command" '{"toolName":"bash","toolInput":{"command":42}}' 2
    for prefix in "${denied_prefixes[@]}"; do
      run_copilot_hook_case "denies $prefix" "{\"toolName\":\"bash\",\"toolInput\":{\"command\":\"$prefix\"}}" 2
    done
    run_copilot_hook_case "allows safe Bash" '{"toolName":"bash","toolInput":{"command":"printf ok"}}' 0
    run_copilot_hook_case "passes non-Bash" '{"toolName":"read","toolInput":{"file_path":"README.md"}}' 0
  fi
  if uses_antigravity; then
    local hook="$REPO_ROOT/.gemini/hooks/lazyai/block-destructive-shell.sh"
    [ -x "$hook" ] || { fail_assert "block-destructive-shell Antigravity hook missing or not executable"; return; }
    local objective_hook="$REPO_ROOT/.gemini/hooks/lazyai/objective-workflow-gate.sh"
    [ -x "$objective_hook" ] || { fail_assert "objective-workflow-gate Antigravity hook missing or not executable"; return; }
    local policy="$AGENTS_HOOKS_DIR/block-destructive-shell/POLICY.md"
    local denied_prefixes=()
    if [ -f "$policy" ]; then
      mapfile -t denied_prefixes < <(extract_denied_prefixes "$policy") || fail_assert "block-destructive-shell policy has no deterministic denied command spans"
    fi
    [ "${#denied_prefixes[@]}" -gt 0 ] || fail_assert "block-destructive-shell denied prefix list empty"

    run_antigravity_objective_gate_case "blocks completion claim without evidence" '{"eventName":"AfterAgent","lastAssistantMessage":"Done. Implemented the change."}' 2 deny
    run_antigravity_objective_gate_case "allows completion claim with verification" '{"eventName":"AfterAgent","lastAssistantMessage":"Done.\n\nVerification: bin/doctor --test-hooks passed."}' 0 allow

    run_antigravity_hook_case "fails closed on malformed JSON" '{' 2 deny
    run_antigravity_hook_case "fails closed on missing Bash command" '{"toolName":"run_shell_command","toolInput":{}}' 2 deny
    run_antigravity_hook_case "fails closed on non-string Bash command" '{"toolName":"run_shell_command","toolInput":{"command":42}}' 2 deny
    for prefix in "${denied_prefixes[@]}"; do
      run_antigravity_hook_case "denies $prefix" "{\"toolName\":\"run_shell_command\",\"toolInput\":{\"command\":\"$prefix\"}}" 2 deny
    done
    run_antigravity_hook_case "allows safe Bash" '{"toolName":"run_shell_command","toolInput":{"command":"printf ok"}}' 0 allow
    run_antigravity_hook_case "passes non-Bash" '{"toolName":"read_file","toolInput":{"file_path":"README.md"}}' 0 allow
  fi
  if uses_opencode; then
    run_opencode_hook_tests
  fi
}

main() {
  parse_args "$@"
  $QUIET || {
    printf 'bin/doctor — vibe-lab health check\n'
    printf 'Repo: %s\n\n' "$REPO_ROOT"
  }
  check_canonical_sources
  check_generated_context
  check_workflows
  check_skill_adapters
  if ! scoped_mode || uses_claude || uses_opencode || uses_copilot || uses_antigravity; then
    check_agent_adapters
    check_hook_adapters
  fi
  if ! scoped_mode; then
    check_tdd_contract
    check_memory_contract
  fi
  check_environment
  check_project_config_guardrails
  check_unsupported_pi_surfaces
  check_hook_functionality
  $QUIET || printf '\nSummary: %s failure(s), %s warning(s)\n' "$FAILURES" "$WARNINGS"
  [ "$FAILURES" -eq 0 ] || exit 1
}

main "$@"
