            "name": "startup-self-heal",
            "type": "command",
            "command": startup_hook,
            "timeout": 5000
        }]
    })
if not session:
    hooks.pop("SessionStart", None)

stop = hooks.setdefault("AfterAgent", [])
stop[:] = [h for h in stop if "objective-workflow-gate" not in json.dumps(h)]
if objective_hook:
    stop.append({
        "hooks": [{
            "name": "objective-workflow-gate",
            "type": "command",
