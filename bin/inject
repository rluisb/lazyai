  [ -x "$REPO_ROOT/.gemini/hooks/vibe-lab/objective-workflow-gate.sh" ] && objective_hook='$GEMINI_PROJECT_DIR/.gemini/hooks/vibe-lab/objective-workflow-gate.sh'
