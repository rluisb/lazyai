settings.write_text(json.dumps(data, indent=2, sort_keys=True) + "\n")
PY
}

antigravity_hook_script() {
  local name="$1"
  local hash="$2"
  shift 2
  if [ "$name" = "block-destructive-shell" ]; then
    local denied_literal
    denied_literal="$(python_list_literal "$@")"
    cat <<SCRIPT
#!/usr/bin/env bash
# Generated by bin/inject. Do not edit manually.
# Policy hash: $hash

if ! command -v python3 >/dev/null 2>&1; then
  echo '{"decision": "deny", "reason": "Python3 is required but not found"}'
  exit 2
fi
input="\$(cat)"

JSON_INPUT="\$input" python3 - <<'PY'
import json, os, sys
try:
    data = json.loads(os.environ.get("JSON_INPUT", ""))
except Exception:
    print(json.dumps({"decision": "deny", "reason": "Failed to parse JSON input"}))
    sys.exit(2)

tool_name = data.get("toolName") or data.get("tool_name")
if tool_name not in ("run_shell_command", "run_shell", "Bash", "bash"):
    print(json.dumps({"decision": "allow"}))
    sys.exit(0)

tool_input = data.get("toolInput") or data.get("tool_input")
command = None
if isinstance(tool_input, dict):
    command = tool_input.get("command")
elif isinstance(tool_input, str):
    command = tool_input
else:
    command = data.get("command")

if not isinstance(command, str):
    print(json.dumps({"decision": "deny", "reason": "No command string found"}))
    sys.exit(2)

command = command.strip()
denied_prefixes = $denied_literal
if any(command == p or command.startswith(p + " ") for p in denied_prefixes):
    print(json.dumps({"decision": "deny", "reason": "Destructive shell command blocked by vibe-lab policy"}))
    sys.exit(2)

print(json.dumps({"decision": "allow"}))
sys.exit(0)
PY
SCRIPT
  elif [ "$name" = "startup-self-heal" ]; then
    cat <<SCRIPT
#!/usr/bin/env bash
# Generated by bin/inject. Do not edit manually.
# Policy hash: $hash
REPO_ROOT="\$(cd "\$(dirname "\$0")/../../.." && pwd)"
"\$REPO_ROOT/bin/startup-self-heal" --cli antigravity --event session-start --quiet || true
SCRIPT
  elif [ "$name" = "objective-workflow-gate" ]; then
    cat <<SCRIPT
#!/usr/bin/env bash
# Generated by bin/inject. Do not edit manually.
# Policy hash: $hash

if ! command -v python3 >/dev/null 2>&1; then
  echo '{"decision": "deny", "reason": "Python3 is required but not found"}'
  exit 2
fi
input="\$(cat)"

JSON_INPUT="\$input" python3 - <<'PY'
import json
import os
import re
import sys

BLOCK_REASON = "Completion claim observed without verification evidence. Add a Verification/Tests/Checks line with observed command/result, or state Blocked/Not run with the reason."


def block(reason):
    print(json.dumps({"decision": "deny", "reason": reason}, separators=(",", ":")))
    sys.exit(2)


try:
    data = json.loads(os.environ.get("JSON_INPUT", ""))
except Exception:
    block("objective-workflow-gate could not parse AfterAgent hook JSON")

if not isinstance(data, dict):
    block("objective-workflow-gate expected a JSON object")

event = data.get("eventName") or data.get("event_name") or data.get("hook_event_name") or data.get("hookEventName")
if event and event not in ("AfterAgent", "Stop"):
    print(json.dumps({"decision": "allow"}))
    sys.exit(0)

message = data.get("lastAssistantMessage") or data.get("last_assistant_message")
if not isinstance(message, str):
    block("objective-workflow-gate could not observe lastAssistantMessage")

completion_line = re.compile(r"^\\s*(?:[-*]\\s*)?(?:done|complete|completed|implemented|fixed|changed|updated|shipped)\\b", re.I)
completion_phrase = re.compile(r"\\b(?:i(?:'ve| have)?\\s+)?(?:completed|implemented|fixed|updated|changed)\\b", re.I)
negated = re.compile(r"\\b(?:not|not yet|could not|unable to|blocked|in progress)\\b", re.I)
evidence = re.compile(r"^\\s*(?:[-*]\\s*)?(?:verification|validation|validated|tests?|checks?|smoke|evidence)\\s*:", re.I | re.M)
blocker = re.compile(r"^\\s*(?:[-*]\\s*)?(?:blocked|not run|could not run|missing prerequisite)\\b|\\b(?:verification|validation|tests?)\\s+not\\s+run\\b", re.I | re.M)

claims_completion = False
for line in message.splitlines():
    if completion_line.search(line) or completion_phrase.search(line):
        if not negated.search(line):
            claims_completion = True
            break

if claims_completion and not evidence.search(message) and not blocker.search(message):
    block(BLOCK_REASON)

print(json.dumps({"decision": "allow"}))
sys.exit(0)
PY
SCRIPT
  else
    cat <<SCRIPT
#!/usr/bin/env bash
# Generated by bin/inject. Do not edit manually.
# Policy hash: $hash
# Advisory policy hook for $name. No runtime block is configured yet.
echo '{"decision": "allow"}'
exit 0
SCRIPT
  fi
}

generate_opencode_plugin() {
  local plugin="$REPO_ROOT/.opencode/plugins/vibe-lab-hooks.js"
  local block_hash="none"
  local startup_hash="none"
  local objective_hash="none"
  local denied_js
  denied_js="$(js_array_literal "$@")"
  if [ -f "$AGENTS_HOOKS_DIR/block-destructive-shell/POLICY.md" ]; then
    block_hash="$(policy_hash "$AGENTS_HOOKS_DIR/block-destructive-shell/POLICY.md")"
  fi
  if [ -f "$AGENTS_HOOKS_DIR/startup-self-heal/POLICY.md" ]; then
    startup_hash="$(policy_hash "$AGENTS_HOOKS_DIR/startup-self-heal/POLICY.md")"
  fi
  if [ -f "$AGENTS_HOOKS_DIR/objective-workflow-gate/POLICY.md" ]; then
    objective_hash="$(policy_hash "$AGENTS_HOOKS_DIR/objective-workflow-gate/POLICY.md")"
  fi
  local content gate_js
  gate_js="$(cat <<'JS'
const objectiveGateBlockReason = "Completion claim observed without verification evidence. Add a Verification/Tests/Checks line with observed command/result, or state Blocked/Not run with the reason.";

const completionLinePattern = /^\s*(?:[-*]\s*)?(?:done|complete|completed|implemented|fixed|changed|updated|shipped)\b/i;
const completionPhrasePattern = /\b(?:i(?:'ve| have)?\s+)?(?:completed|implemented|fixed|updated|changed)\b/i;
const negatedCompletionPattern = /\b(?:not|not yet|could not|unable to|blocked|in progress)\b/i;
const evidencePattern = /^\s*(?:[-*]\s*)?(?:verification|validation|validated|tests?|checks?|smoke|evidence)\s*:/im;
const blockerPattern = /^\s*(?:[-*]\s*)?(?:blocked|not run|could not run|missing prerequisite)\b|\b(?:verification|validation|tests?)\s+not\s+run\b/im;

const firstString = (...values) => {
  for (const value of values) {
    if (typeof value === "string" && value.length > 0) return value;
  }
  return "";
};

const textFromParts = (parts) => {
  if (!Array.isArray(parts)) return "";
  return parts
    .map((part) => firstString(part?.text, part?.content))
    .filter((part) => part.length > 0)
    .join("\n");
};

const assistantTextFromEvent = (event) => {
  const message = event?.message ?? event?.properties?.message ?? event?.data?.message;
  const role = message?.role ?? event?.role ?? event?.properties?.role;
  if (role && role !== "assistant") return "";
  return firstString(
    event?.lastAssistantMessage,
    event?.last_assistant_message,
    event?.assistantMessage,
    event?.text,
    event?.properties?.text,
    message?.content,
    message?.text,
    textFromParts(message?.parts),
  );
};

const claimsCompletion = (message) => message
  .split(/\r?\n/)
  .some((line) => (completionLinePattern.test(line) || completionPhrasePattern.test(line)) && !negatedCompletionPattern.test(line));

const objectiveGateReason = (message) => {
  if (typeof message !== "string" || message.length === 0) return "";
  if (!claimsCompletion(message)) return "";
  if (evidencePattern.test(message) || blockerPattern.test(message)) return "";
  return objectiveGateBlockReason;
};
JS
)"
  content="// Generated by bin/inject. Do not edit manually."$'\n'
  content+="// Block policy hash: $block_hash"$'\n'
  content+="// Startup policy hash: $startup_hash"$'\n'
  content+="// Objective gate policy hash: $objective_hash"$'\n\n'
  content+="$gate_js"$'\n'
  content+="import { spawnSync as nodeSpawnSync } from \"node:child_process\";"$'\n'
  content+="import path from \"node:path\";"$'\n\n'
  content+="export const VibeLabHooks = async ({ directory = process.cwd(), spawnSync = nodeSpawnSync } = {}) => {"$'\n'
  content+="  let lastAssistantMessage = \"\";"$'\n'
  content+="  return {"$'\n'
  content+="  event: async ({ event }) => {"$'\n'
  content+="    if (event.type === \"message.updated\") {"$'\n'
  content+="      const message = assistantTextFromEvent(event);"$'\n'
  content+="      if (message) lastAssistantMessage = message;"$'\n'
  content+="      return;"$'\n'
  content+="    }"$'\n'
  content+="    if (event.type === \"session.idle\") {"$'\n'
  content+="      const message = assistantTextFromEvent(event) || lastAssistantMessage;"$'\n'
  content+="      const reason = objectiveGateReason(message);"$'\n'
  content+="      if (reason) throw new Error(reason);"$'\n'
  content+="      return;"$'\n'
  content+="    }"$'\n'
  content+="    if (event.type !== \"session.created\") return;"$'\n'
  content+="    const result = spawnSync(path.join(directory, \"bin\", \"startup-self-heal\"), [\"--cli\", \"opencode\", \"--event\", \"session.created\", \"--quiet\"], { stdio: \"inherit\" });"$'\n'
  content+="    if (typeof result.status === \"number\" && result.status !== 0) {"$'\n'
  content+="      console.warn(\"[vibe-lab] startup self-heal did not fully repair opencode (exit \" + result.status + \")\");"$'\n'
  content+="    }"$'\n'
  content+="  },"$'\n'
  content+="  \"tool.execute.before\": async (input, output) => {"$'\n'
  content+="    if (input.tool !== \"bash\") return;"$'\n'
  content+="    const command = output.args?.command;"$'\n'
  content+="    if (typeof command !== \"string\") {"$'\n'
  content+="      throw new Error(\"Bash command must be a string for vibe-lab policy\");"$'\n'
  content+="    }"$'\n'
  content+="    const trimmed = command.trim();"$'\n'
  content+="    const denied = $denied_js;"$'\n'
  content+="    if (denied.some((prefix) => trimmed === prefix || trimmed.startsWith(prefix))) {"$'\n'
  content+="      throw new Error(\"Destructive shell command blocked by vibe-lab policy\");"$'\n'
  content+="    }"$'\n'
  content+="  },"$'\n'
  content+="  };"$'\n'
  content+="};"$'\n'
  atomic_write "$plugin" "$content"
}

generate_hook_adapters() {
  [ -d "$AGENTS_HOOKS_DIR" ] || return 0
  local do_claude=false
  local do_opencode=false
  local do_copilot=false
  local do_antigravity=false
  if uses_claude; then
    do_claude=true
  fi
  if uses_opencode; then
    do_opencode=true
  fi
  if uses_copilot; then
    do_copilot=true
  fi
  if uses_antigravity; then
    do_antigravity=true
  fi
  if $do_claude; then
    validate_claude_settings_json
    mkdir -p "$REPO_ROOT/.claude/hooks"
  fi
  if $do_opencode; then
    mkdir -p "$REPO_ROOT/.opencode/plugins"
  fi
  if $do_copilot; then
    mkdir -p "$REPO_ROOT/.github/hooks"
  fi
  if $do_antigravity; then
    mkdir -p "$REPO_ROOT/.gemini/hooks/vibe-lab"
  fi
  local block_policy="$AGENTS_HOOKS_DIR/block-destructive-shell/POLICY.md"
  local block_denied=()
  if [ -f "$block_policy" ]; then
    mapfile -t block_denied < <(extract_denied_prefixes "$block_policy") || fail "block-destructive-shell policy has no deterministic denied command spans"
  fi
  for hook_dir in "$AGENTS_HOOKS_DIR"/*/; do
    [ -d "$hook_dir" ] || continue
    local name policy hash script dest
    name="$(basename "$hook_dir")"
    policy="$hook_dir/POLICY.md"
    [ -f "$policy" ] || { warn "Skipping hook $name without POLICY.md"; continue; }
    hash="$(policy_hash "$policy")"
    if [ "$name" = "block-destructive-shell" ]; then
      script="$(claude_hook_script "$name" "$hash" "${block_denied[@]}")"
    else
      script="$(claude_hook_script "$name" "$hash")"
    fi
    if $do_claude; then
      dest="$REPO_ROOT/.claude/hooks/$name.sh"
      atomic_write "$dest" "$script"
      if ! $DRY_RUN; then chmod +x "$dest"; fi
    fi
    if $do_copilot; then
      local copilot_script
      if [ "$name" = "block-destructive-shell" ]; then
        copilot_script="$(copilot_hook_script "$name" "$hash" "${block_denied[@]}")"
      else
        copilot_script="$(copilot_hook_script "$name" "$hash")"
      fi
      dest="$REPO_ROOT/.github/hooks/$name.sh"
      atomic_write "$dest" "$copilot_script"
      if ! $DRY_RUN; then chmod +x "$dest"; fi

      local event_name
      case "$name" in
        block-destructive-shell) event_name="preToolUse" ;;
        startup-self-heal) event_name="sessionStart" ;;
        objective-workflow-gate) event_name="agentStop" ;;
        caveman-memory-promotion) event_name="sessionEnd" ;;
        *) event_name="" ;;
      esac
      if [ -n "$event_name" ]; then
        local json_dest="$REPO_ROOT/.github/hooks/$name.json"
        local json_content
        json_content="$(copilot_hook_json "$event_name" "$name")"
        atomic_write "$json_dest" "$json_content"
      fi
    fi
    if $do_antigravity; then
      local antigravity_script
      if [ "$name" = "block-destructive-shell" ]; then
        antigravity_script="$(antigravity_hook_script "$name" "$hash" "${block_denied[@]}")"
      else
        antigravity_script="$(antigravity_hook_script "$name" "$hash")"
      fi
      dest="$REPO_ROOT/.gemini/hooks/vibe-lab/$name.sh"
      atomic_write "$dest" "$antigravity_script"
      if ! $DRY_RUN; then chmod +x "$dest"; fi
    fi
  done
  if $do_claude; then
    generate_claude_settings
  fi
  if $do_copilot; then
    : # copilot settings are skipped
  fi
  if $do_antigravity; then
    generate_antigravity_settings
  fi
  if $do_opencode; then
    generate_opencode_plugin "${block_denied[@]}"
  fi
  return 0
}

prune_unsupported_pi_surfaces() {
  uses_pi || return 0
  for path in "$REPO_ROOT/.pi/agents" "$REPO_ROOT/.pi/hooks"; do
    [ -e "$path" ] || [ -L "$path" ] || continue
    if $DRY_RUN; then
      log "[DRY RUN] Would remove unsupported Pi surface ${path#$REPO_ROOT/}"
    else
      rm -rf "$path"
    fi
  done
}

clean_artifacts() {
  warn "--clean is conservative; remove generated adapters manually if needed."
}

main() {
  parse_args "$@"
  if $CLEAN; then
    clean_artifacts
    return 0
  fi
  [ -d "$CANON_DIR" ] || fail "Missing canonical directory"
  [ -f "$CANON_DIR/constitution.md" ] || fail "Missing canonical/constitution.md"
  [ -f "$CANON_DIR/clean-code.md" ] || fail "Missing canonical/clean-code.md"
  [ -f "$CANON_DIR/engineering-principles.md" ] || fail "Missing canonical/engineering-principles.md"
  [ -f "$CANON_DIR/llm-engineering-relationships.md" ] || fail "Missing canonical/llm-engineering-relationships.md"

  log "Starting injection (dry_run=$DRY_RUN, surface=$SURFACE)"
  if uses_claude; then
    validate_claude_settings_json
  fi
  if uses_opencode; then
    merge_opencode_instructions
    ensure_opencode_package_module
  fi
  sync_skill_adapters
  prune_unsupported_pi_surfaces
  sync_reference_docs
  generate_agent_adapters
  generate_hook_adapters
  if uses_opencode || uses_pi || uses_copilot || uses_antigravity; then
    generate_context_file "$REPO_ROOT/AGENTS.md" "# How We Work (Constitution)"
  fi
  if uses_claude; then
    generate_context_file "$REPO_ROOT/CLAUDE.md" "# CLAUDE.md"
  fi
  log "Injection complete. Restart affected CLI sessions for changes to take effect."
}

main "$@"
