#!/usr/bin/env bash
# bin/inject — Generate per-CLI context files, agent adapters, and hook adapters.
# Deterministic renderer. Run bin/doctor to validate outputs.
#
# USAGE
#   bin/inject            Generate all adapters
#   bin/inject --dry-run  Show what would change without writing
#   bin/inject --clean    Remove all generated artifacts
#
# INVARIANTS
#   - Never write to $HOME or global config paths.
#   - Merge-only for .claude/settings.json (preserve unknown keys).
#   - Pre-write symlink defense: remove dangling symlinks before writing.
#   - Atomic writes: write to temp file, then mv into place.
#   - Deterministic ordering: LC_ALL=C, sorted globs.
#   - Project-local only: all output paths under $REPO_ROOT.

set -euo pipefail

export LC_ALL=C

REPO_ROOT="$(cd "$(dirname "$0")/.." && pwd)"
CANON_DIR="$REPO_ROOT/canonical"
AGENTS_SKILLS_DIR="$REPO_ROOT/.agents/skills"
AGENTS_AGENTS_DIR="$REPO_ROOT/.agents/agents"
AGENTS_HOOKS_DIR="$REPO_ROOT/.agents/hooks"
INJECT_D="$REPO_ROOT/bin/inject.d"
DRY_RUN=false
CLEAN=false

if [[ "${1:-}" == "--dry-run" ]]; then
  DRY_RUN=true
  shift
elif [[ "${1:-}" == "--clean" ]]; then
  CLEAN=true
  shift
fi
# ── Source Modular Components ───────────────────────────────────────────────

source "$INJECT_D/generate-claude-hook.sh"
source "$INJECT_D/generate-opencode-hook.sh"
source "$INJECT_D/merge-claude-settings.sh"

# ── Helpers ──────────────────────────────────────────────────────────────────

log()  { printf '[inject] %s\n' "$*"; }
warn() { printf '[inject] WARN: %s\n' "$*" >&2; }
fail() { printf '[inject] FAIL: %s\n' "$*" >&2; exit 1; }

# Atomic write: write to temp then mv into place.
atomic_write() {
  local dest="$1"
  local content="$2"
  local tmp
  tmp="$(mktemp "${dest}.XXXXXX")"
  printf '%s' "$content" > "$tmp"
  mv -f "$tmp" "$dest"
}


# ── Dangling Symlink Cleanup ──────────────────────────────────────────────────

cleanup_dangling_symlinks() {
  local targets=( )
  # Known adapter directories that may contain stale agent symlinks
  for dir in "$REPO_ROOT/.claude/agents" "$REPO_ROOT/.pi/agents" "$REPO_ROOT/.opencode/agents"; do
    if [ -d "$dir" ]; then
      for link in "$dir"/*; do
        [ -L "$link" ] || continue
        if [ ! -e "$link" ]; then
          targets+=( "$link" )
        fi
      done
    fi
  done
  if [ ${#targets[@]} -gt 0 ]; then
    for t in "${targets[@]}"; do
      rm -f "$t"
      log "Removed dangling symlink: $t"
    done
  fi
}

# ── Skill Catalog ─────────────────────────────────────────────────────────────

build_skill_catalog() {
  local catalog=""
  for skill_md in $(printf '%s\n' "$AGENTS_SKILLS_DIR"/*/SKILL.md | sort); do
    [ -f "$skill_md" ] || continue
    local skill_name
    skill_name="$(basename "$(dirname "$skill_md")")"
    local description
    description="$(awk '/^---/{c++; next} c==1 && /^description:/{gsub(/^description: */,""); print; exit}' "$skill_md")"
    [ -z "$description" ] && description="$skill_name skill"
    catalog="${catalog}- **${skill_name}**: ${description}
"
  done
  printf '%s' "$catalog"
}

# ── Agent Catalog ─────────────────────────────────────────────────────────────

build_agent_catalog() {
  local catalog=""
  for agent_md in $(printf '%s\n' "$AGENTS_AGENTS_DIR"/*.md 2>/dev/null | sort); do
    [ -f "$agent_md" ] || continue
    local agent_name
    agent_name="$(basename "$agent_md" .md)"
    local description
generate_context_file() {
  local dest="$1"
  local header="$2"

  local constitution clean_code eng_principles
  constitution="$(cat "$CANON_DIR/constitution.md")"
  clean_code="$(cat "$CANON_DIR/clean-code.md")"
  eng_principles="$(cat "$CANON_DIR/engineering-principles.md")"

  local canon_hash
  canon_hash="$(cat "$CANON_DIR/constitution.md" "$CANON_DIR/clean-code.md" "$CANON_DIR/engineering-principles.md" | shasum -a 256 | awk '{print $1}')"

  local skill_catalog agent_catalog
  skill_catalog="$(build_skill_catalog)"
  agent_catalog="$(build_agent_catalog)"

  local content
  content="$(printf '%s\n\n' "$header"
    cat <<SECTION
<!-- GENERATED FILE — do not edit manually. Run bin/inject to regenerate. -->
<!-- Source hash: ${canon_hash} -->

SECTION
    printf '%s\n\n' "$constitution"
    printf '%s\n\n' "$clean_code"
    printf '%s\n\n' "$eng_principles"
    if [ -n "$skill_catalog" ]; then
      printf '## Shared Skills\n\n%s\n' "$skill_catalog"
    fi
    if [ -n "$agent_catalog" ]; then
      printf '## Shared Agents\n\n%s\n' "$agent_catalog"
    fi
  )"

  remove_symlink_if_present "$dest"
  if $DRY_RUN; then
    log "[DRY RUN] Would write: $dest ($(printf '%s' "$content" | wc -c | tr -d ' ') bytes)"
    return
  fi
  atomic_write "$dest" "$content"
  log "Generated: $dest"
}
  )"

  remove_symlink_if_present "$dest"
  if $DRY_RUN; then
    log "[DRY RUN] Would write: $dest ($(printf '%s' "$content" | wc -c | tr -d ' ') bytes)"
    return
  fi
  atomic_write "$dest" "$content"
  log "Generated: $dest"
}

# ── Agent Adapter Generation ──────────────────────────────────────────────────

generate_claude_agent() {
  local agent_md="$1"
  local agent_name
  agent_name="$(basename "$agent_md" .md)"

  local dest="$REPO_ROOT/.claude/agents/${agent_name}.md"
  local body
  body="$(sed '/^---$/,/^---$/d' "$agent_md" | sed '1{/^$/d}')"

  # Extract frontmatter fields
  local description
  description="$(awk '/^---/{c++; next} c==1 && /^description:/{gsub(/^description: */,""); print; exit}' "$agent_md")"
  local skills
  skills="$(awk '/^---/{c++; next} c==1 && /^skills:/{gsub(/^skills: */,""); print; exit}' "$agent_md")"

  # Build Claude-native frontmatter
  local fm=""
  fm="${fm}---\n"
  fm="${fm}name: ${agent_name}\n"
  [ -n "$description" ] && fm="${fm}description: \"${description}\"\n"
  if [ -n "$skills" ]; then
    fm="${fm}skills:\n"
    for s in $(printf '%s' "$skills" | tr ',' ' '); do
      s="$(printf '%s' "$s" | xargs)"
      fm="${fm}  - ${s}\n"
    done
  fi
  fm="${fm}---\n\n"

  local content
  content="$(printf '%b%s' "$fm" "$body")"

  remove_symlink_if_present "$dest"
  mkdir -p "$(dirname "$dest")"
  if $DRY_RUN; then
    log "[DRY RUN] Would write: $dest ($(printf '%s' "$content" | wc -c | tr -d ' ') bytes)"
    return
  fi
  atomic_write "$dest" "$content"
  log "Generated Claude agent: $dest"
}

generate_opencode_agent() {
  local agent_md="$1"
  local agent_name
  agent_name="$(basename "$agent_md" .md)"

  local dest="$REPO_ROOT/.opencode/agents/${agent_name}.md"
  local body
  body="$(sed '/^---$/,/^---$/d' "$agent_md" | sed '1{/^$/d}')"

  # Extract frontmatter fields
  local description
  description="$(awk '/^---/{c++; next} c==1 && /^description:/{gsub(/^description: */,""); print; exit}' "$agent_md")"

  # opencode agents use YAML frontmatter with different fields
  local fm=""
  fm="${fm}---\n"
  fm="${fm}description: \"${description}\"\n"
  fm="${fm}---\n\n"

  local content
  content="$(printf '%b%s' "$fm" "$body")"

  remove_symlink_if_present "$dest"
  mkdir -p "$(dirname "$dest")"
  if $DRY_RUN; then
    log "[DRY RUN] Would write: $dest ($(printf '%s' "$content" | wc -c | tr -d ' ') bytes)"
    return
  fi
  atomic_write "$dest" "$content"
  log "Generated opencode agent: $dest"
}

# ── Pruning Removed Artifacts ─────────────────────────────────────────────────

prune_stale_opencode_plugins() {
  local plugin_dir="$REPO_ROOT/.opencode/plugins"
  [ -d "$plugin_dir" ] || return 0

  local hook_names=()
  for hook_dir in "$AGENTS_HOOKS_DIR"/*/; do
    [ -d "$hook_dir" ] || continue
    hook_names+=("$(basename "$hook_dir")")
  done

  for plugin in "$plugin_dir"/vibe-lab-*.js; do
    [ -f "$plugin" ] || continue
    local basename_plugin
    basename_plugin="$(basename "$plugin" .js)"
    local hook_name="${basename_plugin#vibe-lab-}"
    # Keep: vibe-lab-hooks (aggregated hook plugin)
    if [ "$hook_name" = "hooks" ]; then continue; fi
    local found=0
    for h in "${hook_names[@]}"; do
      if [ "$h" = "$hook_name" ]; then found=1; break; fi
    done
    if [ "$found" -eq 0 ]; then
      log "Pruning stale opencode plugin: $plugin"
      rm -f "$plugin"
    fi
  done
}

prune_stale_agents() {
  # Remove generated agent adapters whose canonical source no longer exists
  for dir in "$REPO_ROOT/.claude/agents" "$REPO_ROOT/.opencode/agents"; do
    [ -d "$dir" ] || continue
    for adapter in "$dir"/*.md; do
      [ -f "$adapter" ] || continue
      local name
      name="$(basename "$adapter" .md)"
      local canonical="$AGENTS_AGENTS_DIR/${name}.md"
      if [ ! -f "$canonical" ]; then
        if $DRY_RUN; then
          log "[DRY RUN] Would prune stale agent adapter: $adapter (canonical $canonical missing)"
        else
          rm -f "$adapter"
          log "Pruned stale agent adapter: $adapter"
        fi
      fi
    done
  done
}
# Remove generated hook adapters whose canonical policy no longer exists.
prune_stale_hooks() {
  for hook_dir in "$AGENTS_HOOKS_DIR"/*/; do
    [ -d "$hook_dir" ] || continue
    local hook_name
    hook_name="$(basename "$hook_dir")"
    [ -f "$hook_dir/POLICY.md" ] && continue  # still exists, not stale

    local claude_hook="$REPO_ROOT/.claude/hooks/${hook_name}.sh"
    local opencode_plugin="$REPO_ROOT/.opencode/plugins/vibe-lab-${hook_name}.js"

    for target in "$claude_hook" "$opencode_plugin"; do
      if [ -f "$target" ]; then
        if $DRY_RUN; then
          log "[DRY RUN] Would prune stale adapter: $target"
        else
          rm -f "$target"
          log "Pruned stale adapter: $target"
        fi
      fi
    done
  done
}
}

# ── Main ─────────────────────────────────────────────────────────────────────

# ── Clean Generated Artifacts ─────────────────────────────────────────────────

clean_artifacts() {
  log "Cleaning generated artifacts..."
  local removed=0

  # Context files (AGENTS.md, CLAUDE.md)
  for gf in AGENTS.md CLAUDE.md; do
    local target="$REPO_ROOT/$gf"
    if [ -f "$target" ] && head -5 "$target" | grep -q "GENERATED FILE"; then
      rm -f "$target"
      log "Removed: $gf"
      removed=$((removed + 1))
    fi
  done

  # Claude agents
  if [ -d "$REPO_ROOT/.claude/agents" ]; then
    for f in "$REPO_ROOT/.claude/agents"/*.md; do
      [ -f "$f" ] || continue
      rm -f "$f"
      log "Removed: .claude/agents/$(basename "$f")"
      removed=$((removed + 1))
    done
  fi

  # Claude hooks
  if [ -d "$REPO_ROOT/.claude/hooks" ]; then
    for f in "$REPO_ROOT/.claude/hooks"/*.sh; do
      [ -f "$f" ] || continue
      rm -f "$f"
      log "Removed: .claude/hooks/$(basename "$f")"
      removed=$((removed + 1))
    done
  fi

  # Claude settings.json (only if we generated it)
  local settings="$REPO_ROOT/.claude/settings.json"
  if [ -f "$settings" ]; then
    # Only remove if it contains our hook wiring
    if python3 -c "import json,sys; d=json.load(open('$settings')); hooks=d.get('hooks',{}).get('PreToolUse',[]); sys.exit(0 if any('block-destructive-shell' in str(h) for h in hooks) else 1)" 2>/dev/null; then
      rm -f "$settings"
      log "Removed: .claude/settings.json"
      removed=$((removed + 1))
    else
      warn "Skipping .claude/settings.json — does not contain generated hook wiring (may be user-owned)"
    fi
  fi

  # opencode agents
  if [ -d "$REPO_ROOT/.opencode/agents" ]; then
    for f in "$REPO_ROOT/.opencode/agents"/*.md; do
      [ -f "$f" ] || continue
      rm -f "$f"
      log "Removed: .opencode/agents/$(basename "$f")"
      removed=$((removed + 1))
    done
  fi

  # opencode plugins
  if [ -d "$REPO_ROOT/.opencode/plugins" ]; then
    for f in "$REPO_ROOT/.opencode/plugins"/vibe-lab-*.js; do
      [ -f "$f" ] || continue
      rm -f "$f"
      log "Removed: .opencode/plugins/$(basename "$f")"
      removed=$((removed + 1))
    done
  fi

  log "Cleaned $removed generated artifact(s)."
# ── Main ─────────────────────────────────────────────────────────────────────

main() {
  if $CLEAN; then
    clean_artifacts
    return
  fi

  log "Starting injection (dry_run=$DRY_RUN)"

  # 0. Validate canonical sources exist
  [ -d "$CANON_DIR" ] || fail "Canonical directory not found: $CANON_DIR"
  [ -f "$CANON_DIR/constitution.md" ] || fail "Missing canonical/constitution.md"
  [ -f "$CANON_DIR/clean-code.md" ] || fail "Missing canonical/clean-code.md"
  [ -f "$CANON_DIR/engineering-principles.md" ] || fail "Missing canonical/engineering-principles.md"

  # 1. Clean up dangling symlinks
  if ! $DRY_RUN; then
    cleanup_dangling_symlinks
  fi

  # 2. Generate context files (AGENTS.md, CLAUDE.md)
  generate_context_file "$REPO_ROOT/AGENTS.md" "# How We Work (Constitution)"
  generate_context_file "$REPO_ROOT/CLAUDE.md" "# CLAUDE.md"

  # 3. Generate agent adapters
  if [ -d "$AGENTS_AGENTS_DIR" ]; then
    for agent_md in "$AGENTS_AGENTS_DIR"/*.md; do
      [ -f "$agent_md" ] || continue
      generate_claude_agent "$agent_md"
      generate_opencode_agent "$agent_md"
    done
  fi

  # 4. Generate hook adapters
  if [ -d "$AGENTS_HOOKS_DIR" ]; then
    for hook_dir in "$AGENTS_HOOKS_DIR"/*/; do
      [ -d "$hook_dir" ] || continue
      local hook_name
      hook_name="$(basename "$hook_dir")"
      [ -f "$hook_dir/POLICY.md" ] || { warn "No POLICY.md in $hook_dir; skipping"; continue; }
      generate_claude_hook "$hook_name"
      generate_opencode_hook "$hook_name"
    done
  fi

  # 5. Prune stale artifacts
  prune_stale_agents
  prune_stale_hooks

  # 6. Reminder
  log "Injection complete."
  if ! $DRY_RUN; then
    log "Restart opencode and OMP/Pi sessions for changes to take effect."
  fi
}

main "$@"