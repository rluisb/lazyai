<context-engineering>
  <principles>
    <principle id="relevance">Provide only task-relevant context to minimize noise</principle>
    <principle id="recency">Prioritize recent and actively-modified code</principle>
    <principle id="locality">Include nearby code and related files</principle>
    <principle id="completeness">Include all dependencies needed to understand the task</principle>
  </principles>
  
  <context-sources>
    <source priority="1">Current file and immediate imports</source>
    <source priority="2">Related test files</source>
    <source priority="3">Type definitions and interfaces</source>
    <source priority="4">Documentation and ADRs</source>
    <source priority="5">Recent git changes</source>
  </context-sources>
  
  <context-limits>
    <max-files>15</max-files>
    <max-lines-per-file>500</max-lines-per-file>
    <prefer-focused-snippets>true</prefer-focused-snippets>
  </context-limits>
</context-engineering>
