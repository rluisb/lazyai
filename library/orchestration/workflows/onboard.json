{
  "kind": "workflow",
  "name": "onboard",
  "description": "Codebase onboarding workflow using the onboarding chain",
  "version": "1.0.0",
  "entry": "onboard_contributor",
  "phases": [
    {
      "id": "onboard_contributor",
      "kind": "chain",
      "ref": "onboard",
      "on": {
        "success": "complete",
        "failure": "handoff"
      }
    },
    {
      "id": "handoff",
      "kind": "terminal"
    },
    {
      "id": "complete",
      "kind": "terminal"
    }
  ]
}
