{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "memory": {
      "type": "local",
      "enabled": true,
      "command": [
        "npx",
        "-y",
        "@modelcontextprotocol/server-memory"
      ]
    },
    "github": {
      "type": "local",
      "enabled": true,
      "command": [
        "npx",
        "-y",
        "@modelcontextprotocol/server-github"
      ],
      "environment": {
        "GITHUB_TOKEN": "{env:GITHUB_TOKEN}"
      }
    },
    "filesystem": {
      "type": "local",
      "enabled": true,
      "command": [
        "npx",
        "-y",
        "@modelcontextprotocol/server-filesystem",
        "."
      ]
    },
    "ripgrep": {
      "type": "local",
      "enabled": true,
      "command": [
        "npx",
        "-y",
        "mcp-ripgrep"
      ]
    },
    "memoria": {
      "type": "local",
      "enabled": true,
      "command": [
        "npx",
        "-y",
        "@byronwade/memoria"
      ]
    },
    "codegraph": {
      "type": "local",
      "enabled": true,
      "command": [
        "codegraph",
        "serve",
        "--mcp"
      ]
    },
    "qmd": {
      "type": "local",
      "enabled": true,
      "command": [
        "qmd",
        "mcp"
      ]
    },
    "playwright": {
      "type": "local",
      "enabled": false,
      "command": [
        "npx",
        "-y",
        "@playwright/mcp",
        "--headless"
      ]
    },
    "orchestrator": {
      "type": "local",
      "enabled": true,
      "command": ["/Users/ricardoborges/.nvm/versions/node/v24.14.0/bin/ai-setup-orchestrator", "connect"]
    },
    "context7": {
      "type": "remote",
      "enabled": false,
      "url": "https://mcp.context7.com/mcp",
      "headers": {
        "Authorization": "Bearer {env:CONTEXT7_API_KEY}"
      }
    },
    "atlassian": {
      "type": "local",
      "enabled": false,
      "command": [
        "npx",
        "-y",
        "mcp-remote@latest",
        "https://mcp.atlassian.com/v1/mcp"
      ]
    },
    "brave-search": {
      "type": "local",
      "enabled": false,
      "command": [
        "npx",
        "-y",
        "@modelcontextprotocol/server-brave-search"
      ],
      "environment": {
        "BRAVE_API_KEY": "{env:BRAVE_API_KEY}"
      }
    },
    "fetch": {
      "type": "local",
      "enabled": false,
      "command": [
        "npx",
        "-y",
        "@modelcontextprotocol/server-fetch"
      ]
    }
  }
}
