{
  "name": "ai-setup-monorepo",
  "version": "0.0.0",
  "private": true,
  "description": "Monorepo for ai-setup (Go + TypeScript peer implementations, orchestrator)",
  "type": "module",
  "scripts": {
    "build": "pnpm -r --filter=./packages/* run build",
    "test": "pnpm -r --filter=./packages/* run test",
    "typecheck": "pnpm -r --filter=./packages/* run typecheck",
    "lint": "pnpm -r --filter=./packages/* run lint",
    "build:go": "make -C packages/ai-setup-go build",
    "test:go": "make -C packages/ai-setup-go test",
    "test:all": "pnpm run test && pnpm run test:go"
  },
  "engines": {
    "node": ">=20.12.0",
    "pnpm": ">=9"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.10"
  },
  "license": "MIT"
}
