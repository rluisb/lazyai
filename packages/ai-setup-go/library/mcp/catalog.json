{
  "servers": {
    "memory": {
      "description": "Knowledge graph memory for AI sessions",
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-memory"],
      "tools": ["create_entities", "search_nodes", "add_observations", "read_graph"],
      "enabled": true,
      "requiresInstall": false
    },
    "filesystem": {
      "description": "Local filesystem read/write access",
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-filesystem", "."],
      "tools": ["read_file", "write_file", "list_directory", "search_files"],
      "enabled": true,
      "requiresInstall": false
    },
    "ripgrep": {
      "description": "Fast code search via ripgrep",
      "command": "npx",
      "args": ["-y", "mcp-ripgrep"],
      "tools": ["search", "list-files"],
      "enabled": true,
      "requiresInstall": false
    },
    "memoria": {
      "description": "Git history analysis and code memory",
      "command": "npx",
      "args": ["-y", "@byronwade/memoria"],
      "tools": ["get_context", "ask_history", "search_memories"],
      "enabled": true,
      "requiresInstall": false
    },
    "codegraph": {
      "description": "Code knowledge graph for semantic exploration",
      "command": "codegraph",
      "args": ["serve", "--mcp"],
      "tools": ["codegraph_context", "codegraph_search", "codegraph_files"],
      "enabled": true,
      "requiresInstall": true,
      "installHint": "bun install -g codegraph"
    },
    "qmd": {
      "description": "Markdown knowledge base search",
      "command": "qmd",
      "args": ["mcp"],
      "tools": ["query", "get"],
      "enabled": true,
      "requiresInstall": true,
      "installHint": "brew install qmd"
    },
    "graphify": {
      "description": "Knowledge graph builder and query engine for codebases",
      "command": "graphify",
      "args": ["query"],
      "tools": ["query_graph", "get_node", "get_neighbors", "get_community", "god_nodes", "graph_stats", "shortest_path"],
      "enabled": true,
      "requiresInstall": true,
      "installHint": "brew install graphify"
    },
    "obsidian": {
      "description": "Obsidian vault read/write access for persistent knowledge",
      "command": "ob",
      "args": ["mcp"],
      "tools": ["read_note", "write_note", "search_notes", "list_notes"],
      "enabled": true,
      "requiresInstall": true,
      "installHint": "npm install -g obsidian-cli"
    },
    "playwright": {
      "description": "Browser automation and testing",
      "command": "npx",
      "args": ["-y", "@playwright/mcp", "--headless"],
      "tools": ["browser_navigate", "browser_snapshot", "browser_click", "browser_type", "browser_take_screenshot"],
      "enabled": false,
      "requiresInstall": false
    },
    "context7": {
      "description": "Library documentation lookup",
      "url": "https://mcp.context7.com/mcp",
      "headers": { "Authorization": "Bearer ${CONTEXT7_API_KEY}" },
      "tools": ["resolve-library-id", "query-docs"],
      "enabled": false,
      "requiresInstall": false
    },
    "atlassian": {
      "description": "Jira and Confluence read-only access (search issues, read pages via OAuth)",
      "command": "npx",
      "args": ["-y", "mcp-remote@latest", "https://mcp.atlassian.com/v1/mcp"],
      "tools": ["searchAtlassian", "getJiraIssue", "searchJiraIssuesUsingJql", "getConfluencePage"],
      "enabled": false,
      "requiresInstall": false
    },
    "brave-search": {
      "description": "Web search via Brave Search API",
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-brave-search"],
      "env": { "BRAVE_API_KEY": "${BRAVE_API_KEY}" },
      "tools": ["brave_web_search"],
      "enabled": false,
      "requiresInstall": false
    },
    "fetch": {
      "description": "HTTP fetch for web content retrieval",
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-fetch"],
      "tools": ["fetch"],
      "enabled": false,
      "requiresInstall": false
    },
    "orchestrator": {
      "description": "Optional orchestration control plane for chains, teams, and workflows",
      "command": "npx",
      "args": ["-y", "@ai-setup/orchestrator"],
      "tools": ["list_catalog", "compose_agent", "start_chain", "advance_chain", "get_status", "get_budget", "retry_step", "escalate_step", "handoff"],
      "enabled": false,
      "requiresInstall": false
    }
  },
  "cliTools": {
    "gh": {
      "description": "GitHub CLI for repository, issue, and PR operations (never pushes without explicit user approval)",
      "installHint": "brew install gh",
      "enabled": true
    },
    "rtk": {
      "description": "Token-efficient output formatting",
      "installHint": "brew install rtk",
      "enabled": false
    }
  }
}
