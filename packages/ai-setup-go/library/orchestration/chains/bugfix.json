{
  "kind": "chain",
  "name": "bugfix",
  "description": "Bug investigation and repair with explicit root-cause confirmation",
  "version": "1.0.0",
  "entry": "reproduce",
  "domain_skill_injection": "all_steps",
  "mode_skill_injection": "builder_steps_only",
  "steps": [
    {
      "id": "reproduce",
      "agent": "scout",
      "skills": ["research"],
      "description": "Reproduce the issue and capture the failing path with the smallest reliable case.",
      "transitions": {
        "success": "diagnose",
        "failure": {
          "retry": 1,
          "then": "handoff"
        }
      }
    },
    {
      "id": "diagnose",
      "agent": "scout",
      "skills": ["research"],
      "description": "Identify the likely root cause and pause if a human needs to confirm the diagnosis.",
      "gate": "user_approval",
      "transitions": {
        "approved": "fix",
        "rejected": "reproduce"
      }
    },
    {
      "id": "fix",
      "agent": "builder",
      "skills": ["iterate", "tdd-loop"],
      "description": "Implement the fix, add regression coverage, and rerun the failing checks.",
      "transitions": {
        "success": "verify",
        "failure": {
          "retry": 2,
          "then": "handoff"
        }
      }
    },
    {
      "id": "verify",
      "agent": "reviewer",
      "skills": [],
      "description": "Verify the fix addressed the regression without introducing new issues.",
      "transitions": {
        "pass": "document",
        "blocking": "fix"
      }
    },
    {
      "id": "document",
      "agent": "documenter",
      "skills": ["memory-write"],
      "description": "Capture the incident lesson and any follow-up documentation for the fix.",
      "transitions": {
        "success": "done"
      }
    }
  ]
}
