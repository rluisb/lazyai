{
  "$id": "https://lazyai.dev/schemas/eval-case.schema.json",
  "title": "Eval case",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "id",
    "title",
    "input",
    "expected"
  ],
  "properties": {
    "id": {
      "type": "string",
      "minLength": 1
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "input": {
      "type": "object"
    },
    "expected": {
      "type": "object"
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "rubric": {
      "type": "array"
    },
    "holdout": {
      "type": "boolean"
    }
  }
}
