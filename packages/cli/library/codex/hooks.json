{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "\"$(git rev-parse --show-toplevel)/.codex/hooks/lazyai/block-destructive-shell.sh\"",
            "timeout": 10,
            "statusMessage": "Checking shell command for destructive patterns"
          }
        ]
      }
    ]
  }
}
