{
  "version": "1.0",
  "servers": {
    "ai-memory": {
      "description": "Long-term project memory, handoffs, and durable annotations for agent workflows",
      "url": "http://127.0.0.1:49374/mcp",
      "tools": [
        "memory_query",
        "memory_recent",
        "memory_handoff_accept",
        "memory_write_page",
        "memory_auto_improve",
        "memory_consolidate"
      ],
      "enabled": true,
      "requiresInstall": true,
      "installHint": "curl -fsSL https://raw.githubusercontent.com/akitaonrails/ai-memory/main/bin/ai-memory -o ~/.local/bin/ai-memory && chmod +x ~/.local/bin/ai-memory",
      "setupHint": "Start the ai-memory server, then point clients at http://127.0.0.1:49374/mcp or a remote /mcp endpoint. Add an Authorization header when bearer auth is enabled.",
      "preferred_interface": "hybrid",
      "cli_equivalent": "ai-memory",
      "token_policy": "hybrid"
    },
    "filesystem": {
      "description": "Local filesystem read/write access",
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-filesystem",
        "."
      ],
      "tools": [
        "read_file",
        "write_file",
        "list_directory",
        "search_files"
      ],
      "enabled": true,
      "requiresInstall": false,
      "preferred_interface": "cli",
      "cli_equivalent": "lazyai-cli file ops / native shell",
      "token_policy": "cli-first"
    },
    "ripgrep": {
      "description": "Fast code search via ripgrep",
      "command": "npx",
      "args": [
        "-y",
        "mcp-ripgrep"
      ],
      "tools": [
        "search",
        "list-files"
      ],
      "enabled": true,
      "requiresInstall": false,
      "preferred_interface": "cli",
      "cli_equivalent": "rg",
      "token_policy": "cli-first"
    },
    "codegraph": {
      "description": "Code knowledge graph for semantic exploration",
      "command": "codegraph",
      "args": [
        "serve",
        "--mcp"
      ],
      "tools": [
        "codegraph_context",
        "codegraph_search",
        "codegraph_files"
      ],
      "enabled": true,
      "requiresInstall": true,
      "installHint": "bun install -g codegraph",
      "setupHint": "Initialize your repository index by running: codegraph init",
      "preferred_interface": "hybrid",
      "cli_equivalent": "codegraph",
      "token_policy": "hybrid"
    },
    "obsidian": {
      "description": "Obsidian vault read/write access for persistent knowledge",
      "command": "ob",
      "args": [
        "mcp"
      ],
      "tools": [
        "read_note",
        "write_note",
        "search_notes",
        "list_notes"
      ],
      "enabled": true,
      "requiresInstall": true,
      "installHint": "npm install -g obsidian-cli",
      "setupHint": "Ensure the 'Advanced URI' plugin is installed in your Obsidian vault and enabled.",
      "preferred_interface": "hybrid",
      "cli_equivalent": "ob",
      "token_policy": "cli-first"
    }
  },
  "cliTools": {
    "ai-jail": {
      "description": "Sandbox wrapper for AI coding agents with per-project path constraints",
      "installHint": "brew tap akitaonrails/tap && brew install ai-jail",
      "enabled": true
    },
    "ai-memory": {
      "description": "Thin client and installer for the ai-memory project memory server",
      "installHint": "curl -fsSL https://raw.githubusercontent.com/akitaonrails/ai-memory/main/bin/ai-memory -o ~/.local/bin/ai-memory && chmod +x ~/.local/bin/ai-memory",
      "enabled": true
    },
    "gh": {
      "description": "GitHub CLI for repository, issue, and PR operations (never pushes without explicit user approval)",
      "installHint": "brew install gh",
      "enabled": true
    },
    "codegraph": {
      "description": "Code knowledge graph for semantic exploration",
      "installHint": "bun install -g codegraph",
      "enabled": true
    },
    "ob": {
      "description": "Obsidian vault read/write access for persistent knowledge",
      "installHint": "npm install -g obsidian-cli",
      "enabled": true
    }
  }
}
