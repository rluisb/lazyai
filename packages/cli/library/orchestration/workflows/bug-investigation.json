{
  "kind": "workflow",
  "name": "bug-investigation",
  "description": "Bug investigation workflow using the bugfix chain",
  "version": "1.0.0",
  "entry": "investigate_and_fix",
  "phases": [
    {
      "id": "investigate_and_fix",
      "kind": "chain",
      "ref": "bugfix",
      "on": {
        "success": "complete",
        "failure": "handoff"
      }
    },
    {
      "id": "handoff",
      "kind": "terminal"
    },
    {
      "id": "complete",
      "kind": "terminal"
    }
  ]
}
