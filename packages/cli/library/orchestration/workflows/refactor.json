{
  "kind": "workflow",
  "name": "refactor",
  "description": "Refactor workflow using the phased refactor chain",
  "version": "1.0.0",
  "entry": "run_refactor",
  "phases": [
    {
      "id": "run_refactor",
      "kind": "chain",
      "ref": "refactor",
      "on": {
        "success": "complete",
        "failure": "handoff"
      }
    },
    {
      "id": "handoff",
      "kind": "terminal"
    },
    {
      "id": "complete",
      "kind": "terminal"
    }
  ]
}
