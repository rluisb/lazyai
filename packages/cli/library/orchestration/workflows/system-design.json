{
  "kind": "workflow",
  "name": "system-design",
  "description": "Architecture and solution-shaping workflow using the feature team",
  "version": "1.0.0",
  "entry": "shape_options",
  "phases": [
    {
      "id": "shape_options",
      "kind": "team",
      "ref": "feature-team",
      "on": {
        "success": "approve_direction",
        "failure": "handoff"
      }
    },
    {
      "id": "approve_direction",
      "kind": "gate",
      "gate": "user_approval",
      "prompt": "Review the proposed design direction before implementation planning continues.",
      "on": {
        "approved": "complete",
        "rejected": "shape_options"
      }
    },
    {
      "id": "handoff",
      "kind": "terminal"
    },
    {
      "id": "complete",
      "kind": "terminal"
    }
  ]
}
