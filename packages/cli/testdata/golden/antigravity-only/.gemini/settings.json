{
  "hooks": {
    "AfterAgent": [
      {
        "hooks": [
          {
            "command": "$GEMINI_PROJECT_DIR/.gemini/hooks/lazyai/objective-workflow-gate.sh",
            "name": "objective-workflow-gate",
            "timeout": 5000,
            "type": "command"
          }
        ]
      }
    ],
    "BeforeTool": [
      {
        "hooks": [
          {
            "command": "$GEMINI_PROJECT_DIR/.gemini/hooks/lazyai/block-destructive-shell.sh",
            "name": "block-destructive-shell",
            "timeout": 5000,
            "type": "command"
          }
        ],
        "matcher": "run_shell_command"
      }
    ]
  },
  "mcpServers": {
    "ai-memory": {
      "httpUrl": "http://127.0.0.1:49374/mcp"
    },
    "codegraph": {
      "args": [
        "serve",
        "--mcp"
      ],
      "command": "codegraph"
    },
    "filesystem": {
      "args": [
        "-y",
        "@modelcontextprotocol/server-filesystem",
        "."
      ],
      "command": "npx"
    },
    "obsidian": {
      "args": [
        "mcp"
      ],
      "command": "ob"
    },
    "ripgrep": {
      "args": [
        "-y",
        "mcp-ripgrep"
      ],
      "command": "npx"
    }
  }
}
