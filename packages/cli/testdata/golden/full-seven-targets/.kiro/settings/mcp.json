{
  "mcpServers": {
    "ai-memory": {
      "url": "http://127.0.0.1:49374/mcp"
    },
    "codegraph": {
      "args": [
        "serve",
        "--mcp"
      ],
      "command": "codegraph"
    },
    "filesystem": {
      "args": [
        "-y",
        "@modelcontextprotocol/server-filesystem",
        "."
      ],
      "command": "npx"
    },
    "obsidian": {
      "args": [
        "mcp"
      ],
      "command": "ob"
    },
    "ripgrep": {
      "args": [
        "-y",
        "mcp-ripgrep"
      ],
      "command": "npx"
    }
  }
}
