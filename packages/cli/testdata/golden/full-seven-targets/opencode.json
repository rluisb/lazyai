{
  "$schema": "https://opencode.ai/config.json",
  "agent": {
    "build": {
      "permission": {
        "bash": "ask",
        "edit": "ask",
        "skill": {
          "*": "allow"
        }
      }
    },
    "explore": {
      "permission": {
        "bash": "deny",
        "edit": "deny",
        "skill": {
          "*": "allow"
        }
      }
    },
    "plan": {
      "permission": {
        "bash": "ask",
        "edit": "deny",
        "skill": {
          "*": "allow"
        }
      }
    }
  },
  "instructions": [
    "AGENTS.md"
  ],
  "mcp": {
    "ai-memory": {
      "enabled": true,
      "type": "remote",
      "url": "http://127.0.0.1:49374/mcp"
    },
    "codegraph": {
      "command": [
        "codegraph",
        "serve",
        "--mcp"
      ],
      "enabled": true,
      "type": "local"
    },
    "filesystem": {
      "command": [
        "npx",
        "-y",
        "@modelcontextprotocol/server-filesystem",
        "."
      ],
      "enabled": true,
      "type": "local"
    },
    "obsidian": {
      "command": [
        "ob",
        "mcp"
      ],
      "enabled": true,
      "type": "local"
    },
    "ripgrep": {
      "command": [
        "npx",
        "-y",
        "mcp-ripgrep"
      ],
      "enabled": true,
      "type": "local"
    }
  },
  "permission": {
    "skill": {
      "*": "allow"
    }
  },
  "share": "disabled",
  "skills": {
    "paths": [
      ".opencode/skills"
    ]
  }
}
