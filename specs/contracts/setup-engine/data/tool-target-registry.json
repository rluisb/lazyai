{
  "version": 1,
  "canonicalSource": "go",
  "sourceFiles": [
    "internal/types/types.go",
    "internal/adapter/registry.go",
    "internal/adapter/scope.go",
    "internal/globalpaths/globalpaths.go",
    "internal/setupscan/setupscan.go"
  ],
  "pathTokens": {
    "targetDir": "<TARGET_DIR>",
    "homeDir": "<HOME_DIR>"
  },
  "ordering": {
    "tools": "lexicographic-by-id",
    "candidateRoots": "lexicographic-by-origin-then-scope-then-rootPath",
    "desiredExpectedFiles": "lexicographic"
  },
  "tools": [
    {
      "id": "claude-code",
      "name": "Claude Code",
      "supportedScopes": ["global", "project", "workspace"],
      "roots": [
        {
          "scope": "global",
          "origin": "global",
          "rootPath": "<HOME_DIR>/.claude",
          "countRootOnly": false,
          "expectedFiles": ["settings.json"],
          "optionalPaths": ["settings.local.json", "agents", "skills", "commands", "output-styles"],
          "desiredExpectedFiles": ["agents", "commands", "output-styles", "settings.json", "settings.local.json", "skills"],
          "versionFiles": ["settings.json"]
        },
        {
          "scope": "project",
          "origin": "project",
          "rootPath": "<TARGET_DIR>/.claude",
          "countRootOnly": false,
          "expectedFiles": ["settings.json"],
          "optionalPaths": ["settings.local.json", "agents", "skills", "commands", "output-styles"],
          "desiredExpectedFiles": ["agents", "commands", "output-styles", "settings.json", "settings.local.json", "skills"],
          "versionFiles": ["settings.json"]
        },
        {
          "scope": "workspace",
          "origin": "workspace",
          "rootPath": "<TARGET_DIR>/.claude",
          "countRootOnly": false,
          "expectedFiles": ["settings.json"],
          "optionalPaths": ["settings.local.json", "agents", "skills", "commands", "output-styles"],
          "desiredExpectedFiles": ["agents", "commands", "output-styles", "settings.json", "settings.local.json", "skills"],
          "versionFiles": ["settings.json"]
        }
      ]
    },
