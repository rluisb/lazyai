{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ai-setup.local/contracts/setup-engine/setup-dry-run-result.schema.json",
  "title": "Setup Dry Run Result",
  "type": "object",
  "additionalProperties": false,
  "required": ["mode", "scope", "sharedPaths", "targets"],
  "properties": {
    "mode": {"const": "dry-run"},
    "scope": {"$ref": "#/$defs/setupScope"},
    "sharedPaths": {
      "type": "array",
      "items": {"$ref": "#/$defs/desiredPath"}
    },
    "targets": {
      "type": "array",
      "items": {"$ref": "#/$defs/setupDryRunTarget"}
    }
  },
  "$defs": {
    "setupScope": {
      "type": "string",
      "enum": ["global", "project", "workspace"]
    },
    "toolId": {
      "type": "string",
      "enum": ["claude-code", "codex", "copilot", "gemini", "opencode", "pi"]
    },
    "resourceState": {
      "type": "string",
      "enum": ["managed", "adoptable", "conflict", "user-owned", "missing"]
    },
    "desiredPath": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "description", "path"],
      "properties": {
        "id": {"type": "string", "minLength": 1},
        "description": {"type": "string"},
        "path": {"type": "string", "minLength": 1}
      }
    },
    "setupDryRunTarget": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "name", "scope", "origin", "rootPath", "expectedFiles", "existingStatus", "action"],
      "properties": {
        "id": {"$ref": "#/$defs/toolId"},
        "name": {"type": "string", "minLength": 1},
        "scope": {"$ref": "#/$defs/setupScope"},
        "origin": {"type": "string", "enum": ["global", "project", "workspace"]},
        "rootPath": {"type": "string", "minLength": 1},
        "expectedFiles": {
          "type": "array",
          "items": {"type": "string", "minLength": 1},
          "uniqueItems": true
        },
        "observedFiles": {
          "type": "array",
          "items": {"type": "string", "minLength": 1},
          "uniqueItems": true
        },
        "existingStatus": {"type": "string", "enum": ["missing", "detected"]},
        "existingState": {"$ref": "#/$defs/resourceState"},
        "action": {"type": "string", "enum": ["initialize", "preserve-existing"]}
      }
    }
  }
}
